<div metal:use-macro="load: ../shared/_layout.pt"
     xmlns:tal="http://xml.zope.org/namespaces/tal"
     xmlns:metal="http://xml.zope.org/namespaces/metal">
    <main metal:fill-slot="content" class="container">
        <h1 tal:condition="not room">Add Room</h1>
        <h1 tal:condition="room">Edit Room: <span tal:replace="room.name">Room</span></h1>
        
        <form method="post" class="admin-form">
            <div class="form-group">
                <label for="id">ID (Unique Key)</label>
                <input type="text" id="id" name="id" tal:attributes="value room.id; readonly room" required>
            </div>
            <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" tal:attributes="value room.name" required>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/admin/rooms" class="btn">Cancel</a>
            </div>
        </form>
    </main>
</div>
