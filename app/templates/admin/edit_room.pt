<div metal:use-macro="load: ../shared/_layout.pt"
     xmlns:tal="http://xml.zope.org/namespaces/tal"
     xmlns:metal="http://xml.zope.org/namespaces/metal">
    <main metal:fill-slot="content" class="container mt-4 text-white">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm text-dark">
                    <div class="card-header bg-primary text-white">
                        <h3 class="card-title mb-0" tal:condition="not room">Add Room</h3>
                        <h3 class="card-title mb-0" tal:condition="room">Edit Room: <span tal:replace="room.name">Room</span></h3>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <div class="mb-3">
                                <label for="name" class="form-label">Name</label>
                                <input type="text" id="name" name="name" class="form-control" tal:attributes="value python: room.name if room else ''" required>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <a href="/admin/rooms" class="btn btn-outline-secondary">
                                    <i class="bi bi-x-circle me-1"></i>Cancel
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle me-1"></i>Save Room
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
