<div metal:use-macro="load: ../shared/_layout.pt"
     xmlns:tal="http://xml.zope.org/namespaces/tal"
     xmlns:metal="http://xml.zope.org/namespaces/metal">
    <main metal:fill-slot="content" class="container mt-4 text-white">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Rooms Management</h1>
            <div class="btn-group" role="group">
                <a href="/admin/rooms/add" class="btn btn-success">
                    <i class="bi bi-plus-circle me-1"></i>Add Room
                </a>
                <a href="/admin/heaters" class="btn btn-light">
                    <i class="bi bi-cpu me-1"></i>Manage Heaters
                </a>
            </div>
        </div>
        
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Name</th>
                                <th>Heaters</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr tal:repeat="room rooms">
                                <td tal:content="room.name" class="fw-bold">Name</td>
                                <td>
                                    <span class="badge bg-info text-dark" tal:content="python: len(room.heaters)">0</span>
                                </td>
                                <td class="text-end">
                                    <a tal:attributes="href python: '/admin/rooms/edit/{}'.format(room.id)" 
                                       class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form tal:attributes="action python: '/admin/rooms/delete/{}'.format(room.id)" 
                                          method="post" class="d-inline" onsubmit="return confirm('Are you sure?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
</div>
