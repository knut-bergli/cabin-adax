<div metal:use-macro="load: ../shared/_layout.pt"
     xmlns:tal="http://xml.zope.org/namespaces/tal"
     xmlns:metal="http://xml.zope.org/namespaces/metal">
    <main metal:fill-slot="content" class="container mt-4 text-white">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-sm text-dark">
                    <div class="card-header bg-primary text-white">
                        <h3 class="card-title mb-0" tal:condition="not heater">Add Heater</h3>
                        <h3 class="card-title mb-0" tal:condition="heater">Edit Heater: <span tal:replace="heater.name">Heater</span></h3>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <label for="name" class="form-label">Name</label>
                                    <input type="text" id="name" name="name" class="form-control" tal:attributes="value python: heater.name if heater else ''" required>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="type" class="form-label">Type</label>
                                    <select id="type" name="type" class="form-select" required>
                                        <option value="Adax" tal:attributes="selected python: heater.type == 'Adax' if heater else False">Adax</option>
                                        <option value="Mill" tal:attributes="selected python: heater.type == 'Mill' if heater else False">Mill</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="room_id" class="form-label">Room</label>
                                    <select id="room_id" name="room_id" class="form-select">
                                        <option value="">None</option>
                                        <option tal:repeat="room rooms" tal:attributes="value room.id; selected python: heater.room_id == room.id if heater else False" tal:content="room.name">Room</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="current_temp" class="form-label">Current Temp (&deg;C)</label>
                                    <input type="number" step="0.1" id="current_temp" name="current_temp" class="form-control" tal:attributes="value heater.current_temp if heater else 0.0" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="setpoint" class="form-label">Setpoint (&deg;C)</label>
                                    <input type="number" step="0.5" id="setpoint" name="setpoint" class="form-control" tal:attributes="value heater.setpoint if heater else 20.0" required>
                                </div>
                            </div>

                            <div class="mb-4">
                                <div class="form-check form-switch">
                                    <input type="checkbox" id="is_on" name="is_on" value="True" class="form-check-input" tal:attributes="checked python: heater.is_on if heater else True">
                                    <label for="is_on" class="form-check-label">Heater Power Status (ON/OFF)</label>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <a href="/admin/heaters" class="btn btn-outline-secondary">
                                    <i class="bi bi-x-circle me-1"></i>Cancel
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle me-1"></i>Save Heater
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
