<div metal:use-macro="load: ../shared/_layout.pt"
     xmlns:tal="http://xml.zope.org/namespaces/tal"
     xmlns:metal="http://xml.zope.org/namespaces/metal">
    <main metal:fill-slot="content" class="container">
        <h1 tal:condition="not heater">Add Heater</h1>
        <h1 tal:condition="heater">Edit Heater: <span tal:replace="heater.name">Heater</span></h1>
        
        <form method="post" class="admin-form">
            <div class="form-group">
                <label for="id">ID (Unique Key)</label>
                <input type="text" id="id" name="id" tal:attributes="value heater.id; readonly heater" required>
            </div>
            <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" tal:attributes="value heater.name" required>
            </div>
            <div class="form-group">
                <label for="type">Type</label>
                <select id="type" name="type" required>
                    <option value="Adax" tal:attributes="selected python: heater.type == 'Adax' if heater else False">Adax</option>
                    <option value="Mill" tal:attributes="selected python: heater.type == 'Mill' if heater else False">Mill</option>
                </select>
            </div>
            <div class="form-group">
                <label for="room_id">Room</label>
                <select id="room_id" name="room_id">
                    <option value="">None</option>
                    <option tal:repeat="room rooms" tal:attributes="value room.id; selected python: heater.room_id == room.id if heater else False" tal:content="room.name">Room</option>
                </select>
            </div>
            <div class="form-group">
                <label for="current_temp">Current Temp</label>
                <input type="number" step="0.1" id="current_temp" name="current_temp" tal:attributes="value heater.current_temp if heater else 0.0" required>
            </div>
            <div class="form-group">
                <label for="setpoint">Setpoint</label>
                <input type="number" step="0.5" id="setpoint" name="setpoint" tal:attributes="value heater.setpoint if heater else 20.0" required>
            </div>
            <div class="form-group">
                <label for="is_on">Is On</label>
                <input type="checkbox" id="is_on" name="is_on" value="True" tal:attributes="checked python: heater.is_on if heater else True">
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/admin/heaters" class="btn">Cancel</a>
            </div>
        </form>
    </main>
</div>
